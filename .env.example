# Supabase - Client (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase - Server only (never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL (used for canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://utamaglobalindocargo.com

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Contact info (optional, used in structured data)
NEXT_PUBLIC_CONTACT_PHONE=+62-xxx-xxxx-xxxx
NEXT_PUBLIC_CONTACT_EMAIL=info@utamaglobalindocargo.com
