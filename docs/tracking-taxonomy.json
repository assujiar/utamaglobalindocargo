{
  "version": "1.0",
  "platform": "GA4 via GTM",
  "events": [
    {
      "name": "page_view",
      "trigger": "Every page load",
      "priority": "P0",
      "parameters": {
        "page_path": "string — URL path",
        "page_title": "string — document title",
        "locale": "string — id|en",
        "device_type": "string — mobile|desktop|tablet"
      }
    },
    {
      "name": "scroll_depth",
      "trigger": "User scrolls past 25%, 50%, 75%, 90% of page height",
      "priority": "P0",
      "parameters": {
        "page_path": "string",
        "depth_percent": "number — 25|50|75|90"
      }
    },
    {
      "name": "cta_click_quote_header",
      "trigger": "Click on header 'Request Quote' button",
      "priority": "P0",
      "parameters": {
        "page_path": "string",
        "locale": "string"
      }
    },
    {
      "name": "cta_click_quote_inline",
      "trigger": "Click on any in-page quote CTA (hero, CTA band, service recirculation)",
      "priority": "P0",
      "parameters": {
        "page_path": "string",
        "section": "string — hero|cta_band|recirculation|service_detail",
        "locale": "string"
      }
    },
    {
      "name": "cta_click_whatsapp",
      "trigger": "Click on WhatsApp CTA (bottom bar, contact page, not-found state)",
      "priority": "P0",
      "parameters": {
        "page_path": "string",
        "locale": "string",
        "device": "string — mobile|desktop",
        "context": "string — bottom_bar|contact|quote_form|track_not_found"
      }
    },
    {
      "name": "form_start_quote",
      "trigger": "Quote form page loads (Step 1 visible)",
      "priority": "P0",
      "parameters": {
        "locale": "string",
        "referrer_page": "string — page that linked to quote form",
        "preselected_service": "string|null — from query param"
      }
    },
    {
      "name": "form_step_quote",
      "trigger": "User completes a quote form step (clicks Next)",
      "priority": "P0",
      "parameters": {
        "step_number": "number — 1|2|3|4",
        "step_name": "string — service|route|cargo|contact",
        "locale": "string"
      }
    },
    {
      "name": "form_submit_quote",
      "trigger": "Quote form final submission succeeds",
      "priority": "P0",
      "isConversion": true,
      "parameters": {
        "service_type": "string — international|domestic|project|hazmat|medical",
        "route_type": "string — export|import|domestic_air|domestic_sea|domestic_land",
        "locale": "string"
      }
    },
    {
      "name": "form_abandon_quote",
      "trigger": "User leaves quote form page (beforeunload) after completing step 1+ without submitting",
      "priority": "P1",
      "parameters": {
        "last_step": "number — 1|2|3",
        "locale": "string"
      }
    },
    {
      "name": "form_submit_contact",
      "trigger": "Contact form submission succeeds",
      "priority": "P1",
      "isConversion": true,
      "parameters": {
        "locale": "string"
      }
    },
    {
      "name": "cta_click_track",
      "trigger": "Track shipment form submitted",
      "priority": "P1",
      "parameters": {
        "page_path": "string",
        "has_result": "boolean — whether tracking number was found"
      }
    },
    {
      "name": "nav_click",
      "trigger": "Navigation item clicked (header, footer, mega-menu, breadcrumb)",
      "priority": "P1",
      "parameters": {
        "nav_item": "string — label of clicked item",
        "nav_location": "string — header|footer|mega_menu|breadcrumb|mobile_overlay"
      }
    },
    {
      "name": "service_card_click",
      "trigger": "Service card clicked (home, services index, recirculation module)",
      "priority": "P1",
      "parameters": {
        "service_name": "string — domestic|international|import_dtd|charter|warehouse|project_cargo",
        "page_path": "string — source page",
        "module": "string — home_grid|services_index|recirculation"
      }
    },
    {
      "name": "recirculation_click",
      "trigger": "Any cross-link or related-content item clicked",
      "priority": "P1",
      "parameters": {
        "source_page": "string",
        "destination_page": "string",
        "module_type": "string — related_services|related_insights|next_step|in_body_link"
      }
    },
    {
      "name": "language_switch",
      "trigger": "Language toggle clicked",
      "priority": "P2",
      "parameters": {
        "from_locale": "string — id|en",
        "to_locale": "string — id|en",
        "page_path": "string"
      }
    },
    {
      "name": "download_click",
      "trigger": "Company profile or resource file downloaded",
      "priority": "P2",
      "parameters": {
        "file_name": "string",
        "page_path": "string"
      }
    },
    {
      "name": "insights_article_read",
      "trigger": "User scrolls to 75%+ of an insights article",
      "priority": "P2",
      "parameters": {
        "article_slug": "string",
        "category": "string"
      }
    },
    {
      "name": "newsletter_subscribe",
      "trigger": "Newsletter email captured (Phase 2)",
      "priority": "P2",
      "isConversion": true,
      "parameters": {
        "page_path": "string",
        "locale": "string"
      }
    }
  ],
  "utmTaxonomy": {
    "source": {
      "values": ["google", "meta", "linkedin", "tiktok", "email", "whatsapp", "referral", "organic"],
      "description": "Platform or origin"
    },
    "medium": {
      "values": ["cpc", "social", "email", "referral", "display", "organic"],
      "description": "Channel type"
    },
    "campaign": {
      "format": "yyyy-mm_{service}_{objective}",
      "examples": ["2026-04_domestic_awareness", "2026-05_import-dtd_lead-gen", "2026-06_brand_awareness"]
    },
    "content": {
      "description": "Creative variant identifier",
      "examples": ["banner-a", "video-testimonial", "carousel-services"]
    },
    "term": {
      "description": "Paid search keyword (SEM only)"
    }
  },
  "conversions": [
    { "event": "form_submit_quote", "ga4ConversionName": "generate_lead", "value": null },
    { "event": "cta_click_whatsapp", "ga4ConversionName": "whatsapp_contact", "value": null },
    { "event": "form_submit_contact", "ga4ConversionName": "contact_form", "value": null },
    { "event": "newsletter_subscribe", "ga4ConversionName": "newsletter_signup", "value": null }
  ]
}
